@page "/"
@page "/login"
@layout EmptyLayout
@rendermode @(new InteractiveServerRenderMode(prerender: false))

@using EducationAssignmentPortal.Components.Layout
@using EducationAssignmentPortal.Models
@using EducationAssignmentPortal.Services
@inject UserService UserService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms

<style>
    body {
        margin: 0;
    }

    .login-wrapper {
        height: 100vh;
        display: flex;
    }

    /* LEFT SIDE */
    .left-panel {
        width: 50%;
        background: linear-gradient(135deg, #4e73df, #224abe);
        color: white;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 40px;
    }

    .left-panel h1 {
        font-size: 40px;
        font-weight: bold;
    }

    .left-panel p {
        margin-top: 15px;
        font-size: 18px;
        text-align: center;
        max-width: 350px;
    }

    /* RIGHT SIDE */
    .right-panel {
        width: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        background-color: #f8f9fc;
    }

    .login-card {
        width: 350px;
        padding: 30px;
        border-radius: 15px;
        background: white;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    }

    .login-title {
        text-align: center;
        font-weight: 600;
        margin-bottom: 20px;
        color: #4e73df;
    }

    .form-control {
        border-radius: 10px;
    }

    .btn-login {
        background-color: #4e73df;
        color: white;
        border-radius: 10px;
        font-weight: 500;
    }

    .btn-login:hover {
        background-color: #224abe;
    }
    .register-link {
    color: #4e73df;
    font-weight: 500;
    text-decoration: none;
}

.register-link:hover {
    text-decoration: underline;
}
</style>

<div class="login-wrapper">

    <!-- LEFT DESIGN SIDE -->
    <div class="left-panel">
        <h1>EduAssign</h1>
        <p>
            Welcome to Education Assignment Portal.  
            Manage assignments, submissions and dashboards easily.
        </p>
    </div>

    <!-- RIGHT LOGIN SIDE -->
    <div class="right-panel">
        <div class="login-card">

            <h4 class="login-title">Login</h4>

            <EditForm Model="@loginStudent" OnValidSubmit="HandleLogin">
                
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label>Email</label>
                    <InputText @bind-Value="loginStudent.Email"
                               class="form-control"
                               placeholder="Enter your email" />
                </div>

                <div class="mb-3">
                    <label>Password</label>
                    <InputText type="password"
                               @bind-Value="loginStudent.Password"
                               class="form-control"
                               placeholder="Enter your password" />
                </div>

                <button type="submit" class="btn btn-login w-100">
                    Login
                </button>
                <div class="text-center mt-3">
                    <span style="font-size:14px;">Don't have an account?</span>
                    <a href="/register" class="register-link"> Register</a>
                </div>
            </EditForm>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger mt-3 text-center">
                    @errorMessage
                </div>
            }

            @if (showLogoutMessage)
            {
                <div class="alert alert-success text-center">
                    You have been logged out successfully.
                </div>
            }

        </div>
    </div>

</div>

@code {
    private LoginModel loginStudent = new LoginModel();
    private string? errorMessage;
    private bool showLogoutMessage = false;

    protected override void OnInitialized()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (uri.Query.Contains("logout=true"))
        {
            showLogoutMessage = true;
        }
    }

    private async Task HandleLogin()
    {
        errorMessage = null; 
        try
        {
            var user = await UserService.ValidateUser(loginStudent.Email, loginStudent.Password);

            if (user != null)
            {
                if (user.Role == "Faculty" && !user.IsApproved)
                {
                    errorMessage = "Your account is waiting for admin approval.";
                    return;
                }

                var customAuthStateProvider = (CustomAuthenticationStateProvider)AuthStateProvider;
                await customAuthStateProvider.UpdateAuthenticationState(user);

                // Handle ReturnUrl
                var queryParams = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(Navigation.ToAbsoluteUri(Navigation.Uri).Query);
                if (queryParams.TryGetValue("ReturnUrl", out var returnUrl))
                {
                    Navigation.NavigateTo(returnUrl!, replace: true);
                    return;
                }

                switch (user.Role)
                {
                    case "Admin":
                        Navigation.NavigateTo("/admin-dashboard", replace: true);
                        break;
                    case "Faculty":
                        Navigation.NavigateTo("/faculty-dashboard", replace: true);
                        break;
                    default:
                        Navigation.NavigateTo("/student-dashboard", replace: true);
                        break;
                }
            }
            else
            {
                errorMessage = "Invalid Email or Password";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "An error occurred during login: " + ex.Message;
        }
    }
}