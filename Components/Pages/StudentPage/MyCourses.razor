@page "/student/mycourses"
@layout StudentLayout
@using EducationAssignmentPortal.Components.Layout
@using EducationAssignmentPortal.Models
@using EducationAssignmentPortal.Data
@inject AppDBContext _context

<div class="page-header">
    <h2><i class="bi bi-book me-2 text-primary"></i>My Courses</h2>
    <p>Browse all available courses on the platform</p>
</div>

@if (courses == null)
{
    <div class="modern-card text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-3 text-muted">Loading courses...</p>
    </div>
}
else if (!courses.Any())
{
    <div class="modern-card text-center py-5">
        <i class="bi bi-journal-x display-3 text-muted opacity-50"></i>
        <h5 class="mt-4 fw-bold text-muted">No courses available</h5>
        <p class="text-muted small">No courses have been added by faculty yet.</p>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var course in courses)
        {
            <div class="col-md-6 col-lg-4">
                <div class="modern-card h-100" style="cursor:default;">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="stat-icon bg-blue-soft" style="margin:0;">
                            <i class="bi bi-journal-bookmark"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-0">@course.CourseName</h6>
                            <span class="badge-m badge-purple-m">@course.CourseCode</span>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-2 mt-3 pt-3" style="border-top:1px solid #e2e8f0;">
                        <i class="bi bi-person-circle text-muted"></i>
                        <span class="small text-muted">Faculty ID: @course.FacultyId</span>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<Course>? courses;

    protected override void OnInitialized()
    {
        courses = _context.Courses.ToList();
    }
}