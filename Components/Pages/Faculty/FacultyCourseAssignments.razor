@* Commented legacy block removed *@

@page "/faculty/course-assignments/{CourseId:int}"
@layout FacultyLayout
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Faculty")]

@using EducationAssignmentPortal.Components.Layout
@using EducationAssignmentPortal.Models
@using EducationAssignmentPortal.Services
@inject AssignmentService AssignmentService
@inject NavigationManager Navigation

<div class="page-header">
    <h2><i class="bi bi-journal-text me-2 text-primary"></i>Course Assignments</h2>
    <p>Assignments linked to this course</p>
</div>

@if (assignments == null)
{
    <div class="modern-card text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-3 text-muted">Loading assignments...</p>
    </div>
}
else if (assignments.Count == 0)
{
    <div class="modern-card text-center py-5">
        <i class="bi bi-journal-x display-3 text-muted opacity-50"></i>
        <h5 class="mt-4 fw-bold text-muted">No assignments found</h5>
        <p class="text-muted small">No assignments have been added for this course yet.</p>
        <button class="btn btn-modern btn-primary-m mt-2"
                @onclick='() => Navigation.NavigateTo("/faculty/add-assignment")'>
            <i class="bi bi-plus-circle"></i> Add Assignment
        </button>
    </div>
}
else
{
    <div class="modern-card">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h5 class="fw-bold mb-0">All Assignments</h5>
            <span class="badge-m badge-info-m">@assignments.Count total</span>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Description</th>
                        <th>Due Date</th>
                        <th>Status</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in assignments)
                    {
                        <tr>
                            <td class="fw-semibold">@a.Title</td>
                            <td class="text-muted small" style="max-width:200px;">
                                @(a.Description?.Length > 60 ? a.Description.Substring(0, 60) + "…" : a.Description)
                            </td>
                            <td>
                                @if (a.DueDate.HasValue)
                                {
                                    <span class="badge-m badge-warning-m">
                                        @a.DueDate.Value.ToString("MMM dd, yyyy")
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">TBD</span>
                                }
                            </td>
                            <td>
                                <span class="badge-m @(a.Status == "Pending" ? "badge-danger-m" : "badge-success-m")">
                                    @a.Status
                                </span>
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-danger btn-modern"
                                        @onclick="() => DeleteAssignment(a.Id)">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="mt-3">
    <button class="btn btn-outline-secondary btn-modern" @onclick="GoBack">
        <i class="bi bi-arrow-left me-1"></i> Back to Courses
    </button>
</div>

<style>
    .badge-info-m { background: #dbeafe; color: #1e40af; }
</style>

@code {
    [Parameter] public int CourseId { get; set; }
    private List<Assignment>? assignments;

    protected override async Task OnInitializedAsync() => await LoadAssignments();

    private async Task LoadAssignments()
    {
        assignments = await AssignmentService.GetAssignmentsByCourseAsync(CourseId);
    }

    private async Task DeleteAssignment(int id)
    {
        await AssignmentService.DeleteAssignmentAsync(id);
        await LoadAssignments();
    }

    private void GoBack() => Navigation.NavigateTo("/faculty/mycourses");
}