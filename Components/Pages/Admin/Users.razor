@page "/admin/users"
@layout AdminLayout
@attribute [Authorize(Roles = "Admin")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))

@using EducationAssignmentPortal.Components.Layout
@using EducationAssignmentPortal.Services
@using EducationAssignmentPortal.Models
@using Microsoft.AspNetCore.Components.Authorization

@inject UserService UserService
@inject NavigationManager Navigation

<div class="page-header">
    <h2><i class="bi bi-people me-2 text-primary"></i>User Management</h2>
    <p>Manage all registered users, approve faculty, and remove accounts</p>
</div>

<div class="modern-card">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="fw-bold mb-0">All Users</h5>
        <span class="badge-m badge-info-m">@users.Count registered</span>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-3 text-muted">Loading users...</p>
        </div>
    }
    else if (users.Count == 0)
    {
        <div class="text-center py-5">
            <i class="bi bi-people display-3 text-muted opacity-50"></i>
            <p class="text-muted mt-3">No users registered yet.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in users)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div class="avatar-circle @GetAvatarClass(user.Role)">
                                        @(user.Name?.Substring(0, 1).ToUpper() ?? "U")
                                    </div>
                                    <div>
                                        <div class="fw-semibold">@user.Name</div>
                                        <div class="small text-muted">@user.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge-m @GetRoleBadge(user.Role)">@user.Role</span>
                            </td>
                            <td>
                                @if (user.IsApproved)
                                {
                                    <span class="badge-m badge-success-m">
                                        <i class="bi bi-check-circle-fill me-1"></i>Verified
                                    </span>
                                }
                                else
                                {
                                    <span class="badge-m badge-warning-m">
                                        <i class="bi bi-clock-fill me-1"></i>Pending
                                    </span>
                                }
                            </td>
                            <td class="text-end">
                                @if (user.Role == "Faculty" && !user.IsApproved)
                                {
                                    <button class="btn btn-sm btn-outline-success btn-modern me-2"
                                            @onclick="() => ApproveFaculty(user.Id)">
                                        <i class="bi bi-person-check"></i> Approve
                                    </button>
                                }
                                <button class="btn btn-sm btn-outline-danger btn-modern"
                                        @onclick="() => DeleteUser(user.Id)">
                                    <i class="bi bi-trash"></i> Remove
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<style>
    .badge-info-m { background: #dbeafe; color: #1e40af; }
</style>

@code {
    [CascadingParameter]
    private Task<AuthenticationState> authenticationStateTask { get; set; } = default!;

    private List<User> users = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        var authState = await authenticationStateTask;
        if (authState.User.Identity?.IsAuthenticated == true && authState.User.IsInRole("Admin"))
            await LoadData();
        else
            Navigation.NavigateTo("/login");
    }

    private async Task LoadData()
    {
        isLoading = true;
        users = UserService.GetAllUsers();
        isLoading = false;
    }

    private async Task ApproveFaculty(int id) { UserService.ApproveFaculty(id); await LoadData(); }
    private async Task DeleteUser(int id) { UserService.DeleteUser(id); await LoadData(); }

    private string GetRoleBadge(string role) => role switch
    {
        "Admin"   => "badge-danger-m",
        "Faculty" => "badge-info-m",
        "Student" => "badge-success-m",
        _         => "badge-warning-m"
    };

    private string GetAvatarClass(string role) => role switch
    {
        "Admin"   => "avatar-circle" ,
        "Faculty" => "avatar-blue",
        _         => "avatar-green"
    };
}
