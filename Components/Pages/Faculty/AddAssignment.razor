@page "/faculty/add-assignment"
@page "/faculty/addassignment"
@page "/add-assignment"
@layout FacultyLayout
@attribute [Authorize(Roles = "Faculty")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))

@using EducationAssignmentPortal.Components.Layout
@using EducationAssignmentPortal.Models
@using EducationAssignmentPortal.Services
@using System.Security.Claims

@inject AssignmentService AssignmentService
@inject CourseService CourseService
@inject NavigationManager Navigation
@inject NotificationService NotificationService

<div class="page-header">
    <h2><i class="bi bi-plus-circle me-2 text-primary"></i>New Assignment</h2>
    <p>Create and publish a new assignment for your students</p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="modern-card">

            <EditForm Model="@assignment" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary class="alert alert-danger mb-4" />

                <!-- COURSE -->
                <div class="mb-4">
                    <label class="form-label">Select Course</label>
                    <InputSelect class="form-select" @bind-Value="assignment.CourseId">
                        <option value="0">— Choose a course —</option>
                        @foreach (var course in courses)
                        {
                            <option value="@course.Id">@course.CourseName (@course.CourseCode)</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => assignment.CourseId)" class="validation-message" />
                </div>

                <!-- TITLE -->
                <div class="mb-4">
                    <label class="form-label">Assignment Title</label>
                    <InputText class="form-control" @bind-Value="assignment.Title"
                               placeholder="e.g. Lab Report 3 – Data Structures" />
                    <ValidationMessage For="@(() => assignment.Title)" class="validation-message" />
                </div>

                <!-- DESCRIPTION -->
                <div class="mb-4">
                    <label class="form-label">Description</label>
                    <InputTextArea class="form-control" @bind-Value="assignment.Description"
                                   rows="5" placeholder="Provide full assignment details, requirements, and instructions..." />
                    <ValidationMessage For="@(() => assignment.Description)" class="validation-message" />
                </div>

                <!-- DUE DATE -->
                <div class="mb-4">
                    <label class="form-label">Due Date</label>
                    <InputDate class="form-control" @bind-Value="assignment.DueDate" />
                    <ValidationMessage For="@(() => assignment.DueDate)" class="validation-message" />
                </div>

                <div class="d-flex gap-3 mt-2">
                    <button type="submit" class="btn btn-modern btn-primary-m flex-fill">
                        <i class="bi bi-check-circle"></i> Publish Assignment
                    </button>
                    <button type="button" class="btn btn-outline-secondary btn-modern"
                            @onclick='() => Navigation.NavigateTo("/faculty/dashboard")'>
                        <i class="bi bi-x"></i> Cancel
                    </button>
                </div>

            </EditForm>
        </div>
    </div>

    <!-- Tip card -->
    <div class="col-lg-3">
        <div class="modern-card" style="background:#f5f3ff; border-color:#ddd6fe;">
            <h6 class="fw-bold mb-3" style="color:#5b21b6;">
                <i class="bi bi-lightbulb me-2"></i>Tips
            </h6>
            <ul class="list-unstyled mb-0" style="font-size:0.85rem; color:#4c1d95; line-height:1.8;">
                <li><i class="bi bi-check2 me-2 text-success"></i>Set a realistic due date</li>
                <li><i class="bi bi-check2 me-2 text-success"></i>Write a clear description</li>
                <li><i class="bi bi-check2 me-2 text-success"></i>Select the correct course</li>
                <li><i class="bi bi-check2 me-2 text-success"></i>Students get notified instantly</li>
            </ul>
        </div>
    </div>
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState> authenticationStateTask { get; set; } = default!;

    private Assignment assignment = new Assignment { DueDate = DateTime.Today.AddDays(7) };
    private List<Course> courses = new();
    private string facultyEmail = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await authenticationStateTask;
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            facultyEmail = user.FindFirst(ClaimTypes.Email)?.Value ?? "";
            var userIdStr = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

            if (int.TryParse(userIdStr, out int facultyId))
            {
                courses = CourseService.GetCoursesByFaculty(facultyId);
            }
        }
    }

    async Task HandleSubmit()
    {
        if (assignment.CourseId == 0) return;

        assignment.FacultyEmail = facultyEmail;

        await AssignmentService.AddAssignmentAsync(assignment);

        await NotificationService.AddNotificationAsync(
            "Student",
            "New Assignment Added",
            $"{assignment.Title} has been uploaded by faculty.",
            "Assignment",
            "/student/assignments"
        );

        Navigation.NavigateTo("/faculty/dashboard");
    }
}