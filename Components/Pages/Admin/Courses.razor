@page "/admin/courses"
@using EducationAssignmentPortal.Components.Layout
@using EducationAssignmentPortal.Models
@using EducationAssignmentPortal.Services
@layout AdminLayout
@attribute [Authorize(Roles = "Admin")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))

@inject CourseService CourseService
@inject NavigationManager Navigation

<div class="page-header">
    <h2><i class="bi bi-mortarboard me-2 text-primary"></i>Course Management</h2>
    <p>View and manage all courses across the platform</p>
</div>

<div class="modern-card">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="fw-bold mb-0">All Courses</h5>
        <span class="badge-m badge-info-m">@courses.Count courses</span>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-3 text-muted">Loading courses...</p>
        </div>
    }
    else if (courses.Count == 0)
    {
        <div class="text-center py-5">
            <i class="bi bi-journal-x display-3 text-muted opacity-50"></i>
            <h5 class="mt-4 fw-bold text-muted">No courses yet</h5>
            <p class="text-muted small">Faculty members can add courses from their dashboard.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Course Name</th>
                        <th>Faculty</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var course in courses)
                    {
                        <tr>
                            <td><span class="badge-m badge-purple-m">@course.CourseCode</span></td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="stat-icon bg-blue-soft"
                                         style="width:36px;height:36px;font-size:1rem;margin:0;border-radius:8px;">
                                        <i class="bi bi-book"></i>
                                    </div>
                                    <span class="fw-semibold">@course.CourseName</span>
                                </div>
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="avatar-circle avatar-blue" style="width:30px;height:30px;font-size:0.8rem;">
                                        @(course.Faculty?.Name?.Substring(0,1).ToUpper() ?? "F")
                                    </div>
                                    <span class="small">@(course.Faculty?.Name ?? "Unassigned")</span>
                                </div>
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-danger btn-modern"
                                        @onclick="() => DeleteCourse(course.Id)">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<style>
    .badge-info-m { background: #dbeafe; color: #1e40af; }
</style>

@code {
    private List<Course> courses = new();
    private bool isLoading = true;

    protected override void OnInitialized() => LoadCourses();

    private void LoadCourses()
    {
        isLoading = true;
        courses = CourseService.GetAllCourses();
        isLoading = false;
    }

    private void DeleteCourse(int id) { CourseService.DeleteCourse(id); LoadCourses(); }
}
