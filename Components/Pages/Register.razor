@page "/register"
@layout EmptyLayout
@rendermode InteractiveServer

@using EducationAssignmentPortal.Components.Layout
@using EducationAssignmentPortal.Models
@using EducationAssignmentPortal.Services
@inject UserService UserService
@inject NavigationManager Navigation

<style>
    body {
        margin: 0;
    }

    .register-wrapper {
        height: 100vh;
        display: flex;
    }

    /* LEFT SIDE */
    .left-panel {
        width: 50%;
        background: linear-gradient(135deg, #4e73df, #224abe);
        color: white;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 40px;
    }

    .left-panel h1 {
        font-size: 40px;
        font-weight: bold;
    }

    .left-panel p {
        margin-top: 15px;
        font-size: 18px;
        text-align: center;
        max-width: 350px;
    }

    /* RIGHT SIDE */
    .right-panel {
        width: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        background-color: #f8f9fc;
    }

    .register-card {
        width: 380px;
        padding: 30px;
        border-radius: 15px;
        background: white;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    }

    .register-title {
        text-align: center;
        font-weight: 600;
        margin-bottom: 20px;
        color: #4e73df;
    }

    .form-control {
        border-radius: 10px;
    }

    .btn-register {
        background-color: #4e73df;
        color: white;
        border-radius: 10px;
        font-weight: 500;
    }

    .btn-register:hover {
        background-color: #224abe;
    }

    .login-link {
        color: #4e73df;
        font-weight: 500;
        text-decoration: none;
    }

    .login-link:hover {
        text-decoration: underline;
    }
</style>

<div class="register-wrapper">

    <!-- LEFT PANEL -->
    <div class="left-panel">
        <h1>EduAssign</h1>
        <p>
            Join the Education Assignment Portal.  
            Register to manage assignments and dashboards easily.
        </p>
    </div>

    <!-- RIGHT PANEL -->
    <div class="right-panel">
        <div class="register-card">

            <h4 class="register-title">Register</h4>

            <EditForm Model="@user" OnValidSubmit="HandleValidSubmit">
              
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label>Name</label>
                    <InputText @bind-Value="user.Name"
                               class="form-control"
                               placeholder="Enter your name" />
                </div>

                <div class="mb-3">
                    <label>Email</label>
                    <InputText @bind-Value="user.Email"
                               class="form-control"
                               placeholder="Enter your email" />
                </div>

                <div class="mb-3">
                    <label>Password</label>
                    <InputText type="password"
                               @bind-Value="user.Password"
                               class="form-control"
                               placeholder="Enter your password" />
                </div>
                <div class="mb-3">
    <label>Register As</label>
    <InputSelect @bind-Value="user.Role" class="form-control">
        <option value="Student">Student</option>
        <option value="Faculty">Faculty</option>
         <option value="Admin">Admin</option>
    </InputSelect>
</div>

                <button type="submit" class="btn btn-register w-100">
                    Register
                </button>
            </EditForm>

            <div class="text-center mt-3">
                <span style="font-size:14px;">Already have an account?</span>
                <a href="/login" class="login-link"> Login</a>
            </div>

        </div>
    </div>

</div>

@if (!string.IsNullOrEmpty(Message))
{
    <div class="alert alert-success mt-3 text-center">
        @Message
    </div>
}

@code {
   private User user = new User();
   private string? Message;

   private async Task HandleValidSubmit()
{
    if (user.Role == "Faculty")
    {
        user.IsApproved = false; // Needs admin approval
         Message = "Registration successful! Wait for admin approval.";
    }
    else
    {
        user.IsApproved = true;
          Message = "Registration successful! You can login now.";
    }

    await UserService.Register(user);

    Navigation.NavigateTo("/login");
     user = new User(); // Clear form
}
   
}

