@inherits LayoutComponentBase
@using EducationAssignmentPortal.Services
@inject NavigationManager Navigation
@inject UserService UserService

<div class="d-flex">

    <!-- Sidebar -->
    <div class="student-sidebar">
        <div class="student-title">
            <div class="brand-icon">
                <i class="bi bi-mortarboard-fill text-white"></i>
            </div>
            <span>EduAssign</span>
        </div>

        <div class="sidebar-section-label">Student Portal</div>

        <nav class="student-nav">

            <NavLink href="/student-dashboard" class="student-link" Match="NavLinkMatch.All">
                <i class="bi bi-house-door"></i> Dashboard
            </NavLink>

            <NavLink href="/student/assignments" class="student-link">
                <i class="bi bi-journal-text"></i> Assignments
            </NavLink>

            <!-- NEW SUBMISSION PAGE -->
            <NavLink href="/student/submit-assignment" class="student-link">
                <i class="bi bi-cloud-arrow-up"></i> Submit Assignment
            </NavLink>

            <NavLink href="/student/mycourses" class="student-link">
                <i class="bi bi-book"></i> My Courses
            </NavLink>

            <NavLink href="/student/grades" class="student-link">
                <i class="bi bi-bar-chart"></i> Grades
            </NavLink>

            <hr class="sidebar-divider" />

            <button class="sidebar-logout-btn" @onclick="ShowLogoutConfirmation">
                <i class="bi bi-box-arrow-right"></i> Logout
            </button>

        </nav>
    </div>

    <!-- Main Content -->
    <div class="student-content flex-fill">
        @Body
    </div>

</div>

<ConfirmationModal
    IsVisible="isLogoutConfirmVisible"
    Title="Logout Confirmation"
    Message="Are you sure you want to logout?"
    YesButtonText="Yes"
    NoButtonText="No"
    OnConfirm="PerformLogout"
    OnCancel="CancelLogout" />

@code {
    private bool isLogoutConfirmVisible = false;

    private void ShowLogoutConfirmation() => isLogoutConfirmVisible = true;
    private void CancelLogout() => isLogoutConfirmVisible = false;

    void PerformLogout()
    {
        isLogoutConfirmVisible = false;
        UserService.LoggedInUser = null;
        Navigation.NavigateTo("/login?logout=true");
    }

    void Logout() => PerformLogout();
}
