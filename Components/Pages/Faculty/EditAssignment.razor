@page "/edit-assignment/{id:int}"
@layout FacultyLayout
@using EducationAssignmentPortal.Components.Layout
@using Microsoft.AspNetCore.Components.Forms
@using EducationAssignmentPortal.Models
@using EducationAssignmentPortal.Services
@inject AssignmentService AssignmentService
@inject NavigationManager Navigation

<h3>Edit Assignment</h3>

@if (assignment == null)
{
    <p>Assignment not found.</p>
}
else
{
    <EditForm Model="@assignment" OnValidSubmit="HandleUpdate">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label>Title</label>
            <InputText class="form-control"
                       @bind-Value="assignment.Title" />
        </div>

        <div class="mb-3">
            <label>Description</label>
            <InputText class="form-control"
                       @bind-Value="assignment.Description" />
        </div>

        <div class="mb-3">
            <label>Due Date</label>
            <InputDate class="form-control"
                       @bind-Value="assignment.DueDate" />
        </div>

        <button class="btn btn-success">Update</button>
    </EditForm>
}

@code {

    [Parameter]
    public int id { get; set; }

    private Assignment? assignment;

    protected override async Task OnInitializedAsync()  
    {
        assignment =await AssignmentService.GetById(id);
    }

    void HandleUpdate()
    {
        AssignmentService.UpdateAssignmentAsync(assignment!);

        Navigation.NavigateTo("/faculty-dashboard");
    }
}
