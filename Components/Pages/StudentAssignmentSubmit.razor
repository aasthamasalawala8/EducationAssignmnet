@page "/student/submit-assignment"
@using EducationAssignmentPortal.Components.Layout
@using Microsoft.AspNetCore.Components.Forms
@layout StudentLayout

<div class="submission-page">

    <div class="submit-card">

        <div class="submit-header">
            <div class="submit-icon">
                <i class="bi bi-cloud-arrow-up-fill"></i>
            </div>

            <div>
                <h1>Submission Page</h1>
                <p>Upload your assignment file with comments</p>
            </div>
        </div>

        <div class="upload-container">

            <div class="upload-header">
                <h3>
                    <i class="bi bi-upload"></i>
                    Submit Assignment
                </h3>

                <div class="upload-tabs">
                    <span class="active-tab">Upload</span>
                    <span>History</span>
                    <span>Help</span>
                </div>
            </div>

            <label class="upload-box">

                <InputFile OnChange="HandleUpload" class="hidden-input" />

                <i class="bi bi-file-earmark-arrow-up-fill upload-big-icon"></i>

                <p>Drag & drop files here or click to browse</p>
                <small>Supported: PDF, DOC, DOCX, ZIP (max 50MB)</small>

            </label>

            @if (!string.IsNullOrEmpty(FileName))
            {
                <div class="uploaded-file">
                    <div class="file-left">
                        <i class="bi bi-file-earmark-check-fill"></i>
                        <div>
                            <strong>@FileName</strong>
                            <small>File selected successfully</small>
                        </div>
                    </div>

                    <div class="file-right">
                        <span>@FileSize MB</span>
                        <span class="status-badge">Ready</span>
                    </div>
                </div>
            }

            <div class="comments-box">
                <label>Comments</label>

                <textarea class="comment-area"
                          @bind="Comments"
                          placeholder="Add submission comments..."></textarea>
            </div>

            <button class="submit-btn" @onclick="SubmitAssignment">
                <i class="bi bi-send-fill"></i>
                Submit Assignment
            </button>

            @if (!string.IsNullOrEmpty(Message))
            {
                <div class="success-message">
                    <i class="bi bi-check-circle-fill"></i>
                    @Message
                </div>
            }

        </div>

    </div>

</div>

@code {

    private string? FileName;
    private string FileSize = "0";
    private string Comments = "";
    private string Message = "";

    private void HandleUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;

        FileName = file.Name;

        FileSize = Math.Round(file.Size / 1024.0 / 1024.0, 2).ToString();

        Message = "";
    }

    private void SubmitAssignment()
    {
        if (string.IsNullOrEmpty(FileName))
        {
            Message = "Please select a file before submitting.";
            return;
        }

        Message = "Assignment submitted successfully!";
    }
}