@page "/faculty/mycourses"
@layout FacultyLayout
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Faculty")]

@using EducationAssignmentPortal.Components.Layout
@using EducationAssignmentPortal.Models
@using EducationAssignmentPortal.Services
@inject CourseService CourseService
@inject UserService UserService
@inject NavigationManager Navigation

<div class="page-header">
    <h2><i class="bi bi-book me-2 text-primary"></i>My Courses</h2>
    <p>Manage your courses and view linked assignments</p>
</div>

<div class="row g-4">

    <!-- ADD COURSE FORM -->
    <div class="col-lg-4">
        <div class="modern-card">
            <h5 class="fw-bold mb-4">
                <i class="bi bi-plus-circle me-2 text-primary"></i>Add New Course
            </h5>
            <EditForm Model="@newCourse" OnValidSubmit="AddCourse">
                <DataAnnotationsValidator />
                <ValidationSummary class="alert alert-danger mb-3" />

                <div class="mb-3">
                    <label class="form-label">Course Name</label>
                    <InputText class="form-control" @bind-Value="newCourse.CourseName"
                               placeholder="e.g. Data Structures" />
                </div>

                <div class="mb-4">
                    <label class="form-label">Course Code</label>
                    <InputText class="form-control" @bind-Value="newCourse.CourseCode"
                               placeholder="e.g. CS301" />
                </div>

                <button type="submit" class="btn btn-modern btn-primary-m w-100">
                    <i class="bi bi-plus-lg"></i> Add Course
                </button>
            </EditForm>
        </div>
    </div>

    <!-- COURSE LIST -->
    <div class="col-lg-8">
        <div class="modern-card">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold mb-0">Your Courses</h5>
                <span class="badge-m badge-info-m">@courses.Count courses</span>
            </div>

            @if (courses.Count == 0)
            {
                <div class="text-center py-5">
                    <i class="bi bi-journal-x display-4 text-muted opacity-50"></i>
                    <p class="text-muted mt-3 mb-0">No courses added yet.</p>
                    <p class="text-muted small">Use the form on the left to add your first course.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Course</th>
                                <th>Code</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in courses)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="stat-icon bg-blue-soft" style="width:36px;height:36px;font-size:1rem;margin:0;border-radius:8px;">
                                                <i class="bi bi-book"></i>
                                            </div>
                                            <span class="fw-semibold">@c.CourseName</span>
                                        </div>
                                    </td>
                                    <td><span class="badge-m badge-purple-m">@c.CourseCode</span></td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-primary btn-modern me-2"
                                                @onclick="() => ViewAssignments(c.Id)">
                                            <i class="bi bi-eye"></i> Assignments
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger btn-modern"
                                                @onclick="() => DeleteCourse(c.Id)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .badge-info-m { background: #dbeafe; color: #1e40af; }
</style>

@code {
    private List<Course> courses = new();
    private Course newCourse = new();

    protected override void OnInitialized() => LoadCourses();

    private void LoadCourses()
    {
        if (UserService.LoggedInUser != null)
            courses = CourseService.GetCoursesByFaculty(UserService.LoggedInUser.Id);
    }

    private void AddCourse()
    {
        if (UserService.LoggedInUser != null)
        {
            newCourse.FacultyId = UserService.LoggedInUser.Id;
            CourseService.AddCourse(newCourse);
            newCourse = new Course();
            LoadCourses();
        }
    }

    private void DeleteCourse(int id) { CourseService.DeleteCourse(id); LoadCourses(); }
    private void ViewAssignments(int courseId) => Navigation.NavigateTo($"/faculty/course-assignments/{courseId}");
}