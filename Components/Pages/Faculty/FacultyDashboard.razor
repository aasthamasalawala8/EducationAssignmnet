@layout FacultyLayout
@page "/faculty/dashboard"
@page "/faculty-dashboard"
@page "/faculty"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Faculty")]

@using EducationAssignmentPortal.Components.Layout
@using EducationAssignmentPortal.Models
@using EducationAssignmentPortal.Services
@using Microsoft.AspNetCore.Components.Authorization

@inject UserService UserService
@inject AssignmentService AssignmentService
@inject NavigationManager Navigation

<div class="container-fluid">
    <AuthorizeView Roles="Faculty">
        <Authorized>
            <div class="welcome-banner shadow-lg">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h1 class="display-5 fw-bold mb-2">Welcome back, @context.User.Identity?.Name!</h1>
                        <p class="lead opacity-75">Manage your courses, assignments, and student performance from one place.</p>
                    </div>
                    <div class="d-none d-lg-block">
                        <i class="bi bi-mortarboard-fill display-1 opacity-25"></i>
                    </div>
                </div>
            </div>
        </Authorized>
    </AuthorizeView>

    <!-- QUICK ACTIONS -->
    <div class="d-flex gap-3 mb-5">
        <button class="btn btn-modern btn-primary-m" @onclick="GoToAddAssignment">
            <i class="bi bi-plus-circle me-1"></i> New Assignment
        </button>
        <button class="btn btn-modern btn-outline-primary" @onclick="GoToMyCourses">
            <i class="bi bi-eye me-1"></i> View Courses
        </button>
        <button class="btn btn-modern btn-outline-warning" @onclick="GoToGrading">
            <i class="bi bi-star me-1"></i> Grade Submissions
        </button>
    </div>

    <!-- STATISTICS -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="modern-card text-center">
                <div class="stat-icon bg-blue-soft text-primary mx-auto">
                    <i class="bi bi-journal-text"></i>
                </div>
                <h5 class="text-muted small uppercase fw-bold">Total Assignments</h5>
                <h2 class="fw-bold mb-0">@totalAssignments</h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="modern-card text-center">
                <div class="stat-icon bg-green-soft text-success mx-auto">
                    <i class="bi bi-book"></i>
                </div>
                <h5 class="text-muted small uppercase fw-bold">Active Courses</h5>
                <h2 class="fw-bold mb-0">@totalCourses</h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="modern-card text-center">
                <div class="stat-icon bg-red-soft text-danger mx-auto">
                    <i class="bi bi-clock-history"></i>
                </div>
                <h5 class="text-muted small uppercase fw-bold">Pending Grading</h5>
                <h2 class="fw-bold mb-0">@pendingAssignments</h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="modern-card text-center">
                <div class="stat-icon bg-purple-soft text-info mx-auto">
                    <i class="bi bi-people"></i>
                </div>
                <h5 class="text-muted small uppercase fw-bold">Total Students</h5>
                <h2 class="fw-bold mb-0">@totalStudents</h2>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- UPCOMING DEADLINES -->
        <div class="col-lg-6">
            <div class="modern-card h-100">
                <h5 class="fw-bold mb-4"><i class="bi bi-calendar-event me-2 text-primary"></i> Upcoming Deadlines</h5>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Assignment</th>
                                <th>Due Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in upcomingAssignments)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-bold">@item.Title</div>
                                        <div class="small text-muted">ID: @item.Id</div>
                                    </td>
                                    <td>
                                        <span class="badge-m badge-warning-m">
                                            @(item.DueDate.HasValue ? item.DueDate.Value.ToString("MMM dd, yyyy") : "TBD")
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- RECENT ASSIGNMENTS -->
        <div class="col-lg-6">
            <div class="modern-card h-100">
                <h5 class="fw-bold mb-4"><i class="bi bi-lightning-charge me-2 text-success"></i> Recent Assignments</h5>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Title</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in recentAssignments)
                            {
                                <tr>
                                    <td>@item.Title</td>
                                    <td>
                                        <span class="badge-m @(item.Status == "Pending" ? "badge-danger-m" : "badge-success-m")">
                                            @item.Status
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState> authenticationStateTask { get; set; } = default!;

    private int totalAssignments;
    private int totalCourses;
    private int pendingAssignments;
    private int totalStudents;

    private List<Assignment> upcomingAssignments = new();
    private List<Assignment> recentAssignments = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardData();
    }

    async Task LoadDashboardData()
    {
        var authState = await authenticationStateTask;
        var email = authState.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value;

        if (!string.IsNullOrEmpty(email))
        {
            var allAssignments = await AssignmentService.GetAllAssignments();

            var assignments = allAssignments
                .Where(a => a.FacultyEmail == email)
                .ToList();

            totalAssignments = assignments.Count;
            pendingAssignments = assignments.Count(a => a.Status == "Pending");
            totalCourses = assignments.Select(a => a.CourseId).Distinct().Count();
            totalStudents = 120; // temporary

            upcomingAssignments = assignments
                .Where(a => a.DueDate.HasValue && a.DueDate.Value >= DateTime.Today)
                .OrderBy(a => a.DueDate)
                .Take(5)
                .ToList();

            recentAssignments = assignments
                .OrderByDescending(a => a.DueDate)
                .Take(5)
                .ToList();
        }
    }

    void GoToAddAssignment() => Navigation.NavigateTo("/faculty/add-assignment");
    void GoToMyCourses() => Navigation.NavigateTo("/faculty/mycourses");
    void GoToGrading() => Navigation.NavigateTo("/faculty/grading");
}