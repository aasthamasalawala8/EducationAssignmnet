@using EducationAssignmentPortal.Services
@using Microsoft.AspNetCore.Components.Authorization

@inject UserService UserService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="/">EducationAssignmentPortal</a>
    </div>
</div>

<div class="nav-scrollable">
    <nav class="flex-column">
        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3 text-white mb-2">
                    <span class="nav-link">
                        👤 @context.User.Identity?.Name
                    </span>
                </div>

                <AuthorizeView Roles="Student" Context="inner">
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="/student-dashboard">
                            Dashboard
                        </NavLink>
                    </div>
                </AuthorizeView>

                <AuthorizeView Roles="Faculty" Context="inner">
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="/faculty-dashboard">
                            Faculty Dashboard
                        </NavLink>
                    </div>
                </AuthorizeView>

                <AuthorizeView Roles="Admin" Context="inner">
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="/admin-dashboard">
                            Admin Panel
                        </NavLink>
                    </div>
                </AuthorizeView>

                <div class="nav-item px-3">
                    <span class="nav-link" style="cursor:pointer;" @onclick="ShowLogoutConfirmation">
                        Logout
                    </span>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/login">
                        Login
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/register">
                        Register
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

<ConfirmationModal 
    IsVisible="isLogoutConfirmVisible" 
    Title="Logout Confirmation" 
    Message="Are you sure you want to logout?"
    YesButtonText="Yes"
    NoButtonText="No"
    OnConfirm="PerformLogout"
    OnCancel="CancelLogout" />

@code {
    private bool isLogoutConfirmVisible = false;

    private void ShowLogoutConfirmation() => isLogoutConfirmVisible = true;
    private void CancelLogout() => isLogoutConfirmVisible = false;

    private async Task PerformLogout()
    {
        isLogoutConfirmVisible = false;
        var customAuthStateProvider = (CustomAuthenticationStateProvider)AuthStateProvider;
        await customAuthStateProvider.UpdateAuthenticationState(null);
        UserService.LoggedInUser = null;
        Navigation.NavigateTo("/login?logout=true");
    }

    // Keep original for possible usage
    private async Task Logout() => await PerformLogout();
}
